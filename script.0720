#!/bin/bash

hostname="172.18.0.1"
port="10086"
destination="root@$hostname"
prv_key="/root/.ssh/id_rsa"
pub_key="/root/.ssh/id_rsa.pub"
pwd
ls -la /
if [ -f "$prv_key" ]; then
	echo "private key pair exists"
else 
	echo "generates key pair"
	ssh-keygen -t rsa
fi
echo "public key:"
cat $pub_key
read input
> /root/.ssh/known_hosts
> /root/.ssh/known_hosts.old
#if ssh-keygen -F "[$hostname]:$port" > /dev/null; then
#	echo "knownhost exists"
#else 
	echo "try to connect $destination"
	#echo "list /usr/bin"	
	#ls -la /usr/bin/
	#ssh-copy-id -p $port -i /root/.ssh/id_rsa.pub $destination
	#ssh-copy-id -p $port $destination
	echo "1-st"
	cat /root/.ssh/known_hosts
	ssh-keyscan -p $port -H $hostname >> /root/.ssh/known_hosts
	echo "2-nd"
	cat /root/.ssh/known_hosts	
	echo "load scripts"

	# ssh -p $port -i $prv_key $destination 'cat /etc/os-release'
	scp -P $port -i $prv_key /root/scripts/* $destination:~/scripts/
	ssh -p $port -i $prv_key $destination 'chmod +x ~/scripts/*'
#fi
#ssh -p $port -i $prv_key $destination 'passwd -l root'

while true; do
	echo "Please select one of the followings to run inside TD [helloworld, script-ps.sh, script-whoami.sh]:"
	read input
	if [[ "$input" == "q" ]]; then
		break
	fi
	ssh -p $port -i $prv_key $destination "~/scripts/$input"
done
