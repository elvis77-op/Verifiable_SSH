#!/bin/bash

hostname="172.18.0.1"
port="10086"
destination="root@$hostname"
prv_key="id_rsa"

#if [ -f "$prv_key" ]; then
#	echo "ssh keys exist"
#else 
#	echo "generate ssh keys"
	ssh-keygen -t rsa
	cp /root/.ssh/id_rsa /root/keys/
	cp /root/.ssh/id_rsa.pub /root/keys/
#fi

> /root/.ssh/known_hosts

if ssh-keygen -F "[$hostname]:$port" > /dev/null; then
	echo "knownhost exists"
else 
	echo "try to connect $destination"
	ls -la /root/keys 
	echo "list /usr/bin"	
	ls -la /usr/bin/
#	ssh-copy-id -p $port -i /root/keys/id_rsa.pub $destination
	ssh-copy-id -p $port $destination

	ssh-keyscan -p $port -H $hostname > /root/.ssh/known_hosts
	echo "load scripts"
	scp -P $port -i $prv_key ./scripts/* $destination:~/scripts/
	ssh -p $port -i $prv_key $destination 'chmod +x ~/scripts/*'
fi
#ssh -p $port -i $prv_key $destination 'passwd -l root'

while true; do
	echo "Please select one of the followings to run inside TD [helloworld, script-ps.sh, script-whoami.sh]:"
	read input
	if [[ "$input" == "q" ]]; then
		break
	fi
	ssh -p $port -i $prv_key $destination "~/scripts/$input"
done
